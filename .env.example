# Database
DATABASE_URL=postgres://agentfarm:localdev@localhost:5432/agentfarm

# Auth
JWT_SECRET=change-me-in-production

# Internal service token — Backend↔Account Manager auth
INTERNAL_SERVICE_TOKEN=local-dev-internal-token

# Account Manager
ACCOUNT_MANAGER_URL=http://localhost:4100

# Backend (used by account-manager)
BACKEND_URL=http://localhost:4000

# Claude (session mode — extracted from local Keychain)
AUTH_MODE=session
# Or: ANTHROPIC_API_KEY=sk-ant-... (API key mode)

# GitHub Plugin (optional)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=

# IRC
ERGO_HOST=localhost
ERGO_PORT=6667

# Email (optional — skip for local dev)
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
